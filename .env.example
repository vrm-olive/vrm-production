# ─── Stripe ───────────────────────────────────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
# Utilisez les clés "test" (sk_test_... / pk_test_...) en développement
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Compte gratuit sur https://resend.com — 3 000 emails/mois inclus
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email de destination pour les formulaires de contact
CONTACT_EMAIL=contact@vrmproduction.com

# ─── Site ─────────────────────────────────────────────────────────────────────
# URL complète du site (sans slash final)
NEXT_PUBLIC_SITE_URL=https://vrmproduction.com
